{
  "name": "project-devops",
  "description": "Infrastructure, CI/CD, deployment, works on devops branch",
  "prompt": "file://./prompts/devops-prompt.md",
  "tools": ["read", "write", "shell", "grep", "glob", "aws"],
  "allowedTools": ["read", "grep", "glob"],
  "toolsSettings": {
    "shell": {
      "allowedCommands": [
        "grep", "find", "wc", "head", "tail", "cat", "diff",
        "git diff", "git log", "git status", "git fetch",
        "git checkout", "git pull", "git push", "git merge",
        "git add", "git commit",
        "gh issue list", "gh issue create", "gh issue close",
        "cdk", "cdk synth", "cdk deploy", "cdk diff", "cdk destroy",
        "aws cloudformation", "npm", "pip"
      ]
    },
    "write": {
      "allowedPaths": ["infra/**"]
    }
  },
  "resources": [
    "file://.kiro/specs/**/*.md",
    "file://.kiro/steering/**/*.md"
  ]
}
